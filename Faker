import sqlite3
from faker import Faker
import random
from datetime import datetime

fake = Faker()

conn = sqlite3.connect("school.db")
cur = conn.cursor()

# groups
groups = ["A1", "B2", "C3"]
for g in groups:
    cur.execute("INSERT INTO groups(name) VALUES (?)", (g,))

# teachers
teacher_ids = []
for _ in range(5):
    cur.execute("INSERT INTO teachers(name) VALUES (?)", (fake.name(),))
    teacher_ids.append(cur.lastrowid)

# subjects
subjects = ["Math", "Physics", "History", "English", "Biology", "CS"]
subject_ids = []

for s in subjects:
    cur.execute(
        "INSERT INTO subjects(name, teacher_id) VALUES (?, ?)",
        (s, random.choice(teacher_ids))
    )
    subject_ids.append(cur.lastrowid)

# students
student_ids = []
for _ in range(40):
    cur.execute(
        "INSERT INTO students(name, group_id) VALUES (?, ?)",
        (fake.name(), random.randint(1, 3))
    )
    student_ids.append(cur.lastrowid)

# grades
for student in student_ids:
    for _ in range(random.randint(10, 20)):
        cur.execute(
            "INSERT INTO grades(student_id, subject_id, grade, date_received) VALUES (?, ?, ?, ?)",
            (
                student,
                random.choice(subject_ids),
                random.randint(60, 100),
                fake.date_time_this_year().isoformat()
            )
        )

conn.commit()
conn.close()
